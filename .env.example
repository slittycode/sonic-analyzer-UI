# Base URL of the local DSP backend that exposes POST /api/analyze
VITE_API_BASE_URL="http://127.0.0.1:8787"

# Optional Gemini phase-2 reconstruction pass in the frontend
VITE_ENABLE_PHASE2_GEMINI="false"
VITE_GEMINI_API_KEY=""

# Optional dev-server knob for environments that need HMR disabled
DISABLE_HMR="false"
